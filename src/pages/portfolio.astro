                      <a href="/portfolio/gearbox" class="details-link"><i class="bi bi-arrow-right"></i></a>
                    </div>
                  </div>
                </div>
                <div class="portfolio-content">
                  <span class="category">Client Work</span>
                  <a href="/portfolio/gearbox"><h3>Gearbox Counter Design</h3></a>
