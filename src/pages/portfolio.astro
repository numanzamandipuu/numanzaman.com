                </div>
              </div>
            </div><!-- End Portfolio Item -->

            <div class="col-lg-6 col-md-6 portfolio-item isotope-item filter-all filter-client">
              <div class="portfolio-card">
                <div class="portfolio-image">
                  <img src="assets/img/portfolio_title/43.jpg" class="img-fluid" alt="" loading="lazy">
                  <div class="portfolio-overlay">
                    <div class="portfolio-actions">
                      <a href="/assets/img/portfolio_title/43.jpg" class="glightbox preview-link" data-gallery="portfolio-gallery-graphics"><i class="bi bi-eye"></i></a>
                      <a href="/portfolio/ford-pickup" class="details-link"><i class="bi bi-arrow-right"></i></a>
                    </div>
                  </div>
                </div>
                <div class="portfolio-content">
                  <span class="category">Client Work</span>
                  <a href="/portfolio/ford-pickup"><h3>1979 Ford Pickup</h3></a>
                  <p>Classic pickup truck geometry reconstructed into a detailed parametric CAD model, optimized for 3D Printing.</p>
                </div>
              </div>
            </div><!-- End Portfolio Item -->

            <div class="col-lg-6 col-md-6 portfolio-item isotope-item filter-all filter-client">
              <div class="portfolio-card">
                <div class="portfolio-image">
                  <img src="assets/img/portfolio_title/40.jpg" class="img-fluid" alt="" loading="lazy">
                  <div class="portfolio-overlay">
                    <div class="portfolio-actions">
