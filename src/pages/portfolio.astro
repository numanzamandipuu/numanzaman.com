                </div>
              </div>
            </div><!-- End Portfolio Item -->

            <div class="col-lg-6 col-md-6 portfolio-item isotope-item filter-all filter-client">
              <div class="portfolio-card">
                <div class="portfolio-image">
                  <img src="assets/img/portfolio_title/42.jpg" class="img-fluid" alt="" loading="lazy">
                  <div class="portfolio-overlay">
                    <div class="portfolio-actions">
                      <a href="/assets/img/portfolio_title/42.jpg" class="glightbox preview-link" data-gallery="portfolio-gallery-graphics"><i class="bi bi-eye"></i></a>
                      <a href="/portfolio/stl-support" class="details-link"><i class="bi bi-arrow-right"></i></a>
                    </div>
                  </div>
                </div>
                <div class="portfolio-content">
                  <span class="category">Client Work</span>
                  <a href="/portfolio/stl-support"><h3>3D Print Support Implementation</h3></a>
                  <p>STL models modified with optimized supports and geometry adjustments to improve print success and structural stability.</p>
                </div>
              </div>
            </div><!-- End Portfolio Item -->

            <div class="col-lg-6 col-md-6 portfolio-item isotope-item filter-all filter-independent">
              <div class="portfolio-card">
                <div class="portfolio-image">
                  <img src="assets/img/portfolio_title/50.jpg" class="img-fluid" alt="" loading="lazy">
                  <div class="portfolio-overlay">
                    <div class="portfolio-actions">
                      <a href="/assets/img/portfolio_title/50.jpg" class="glightbox preview-link" data-gallery="portfolio-gallery-graphics"><i class="bi bi-eye"></i></a>
