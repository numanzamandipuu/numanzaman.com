                      <a href="/portfolio/camera-lens" class="details-link"><i class="bi bi-arrow-right"></i></a>
                    </div>
                  </div>
                </div>
                <div class="portfolio-content">
                  <span class="category">Independent Work</span>
                  <a href="/portfolio/camera-lens"><h3>Canon EF 300mm f2.8L IS II USM</h3></a>
                  <p>Multi-part mechanical assembly replicating internal and external Canon lens components with precision surface detailing.</p>
                </div>
              </div>
            </div><!-- End Portfolio Item -->

            <div class="col-lg-6 col-md-6 portfolio-item isotope-item filter-all filter-client">
              <div class="portfolio-card">
