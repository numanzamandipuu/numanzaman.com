---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="CAD Reconstruction & Reverse Engineering">

<main class="main">


    <!-- Page Title -->
    <div class="page-title">
      <div class="breadcrumbs">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/"><i class="bi bi-house"></i> Home</a></li>
            <li class="breadcrumb-item"><a href="/services">Services</a></li>
            <li class="breadcrumb-item active current">Reverse Engineering</li>
          </ol>
        </nav>
      </div>

      <!-- Section Title -->
      <div class="container section-title pb-0">
        <h2>CAD Reconstruction & Reverse Engineering</h2>
        <div class="title-shape">
          <svg viewBox="0 0 200 20" xmlns="http://www.w3.org/2000/svg">
            <path d="M 0,10 C 40,0 60,20 100,10 C 140,0 160,20 200,10" fill="none" stroke="currentColor" stroke-width="2"></path>
          </svg>
        </div>
        <p>Reconstruction of accurate, editable CAD models from images, reference geometry, or existing components.</p>
      </div><!-- End Section Title -->
    </div><!-- End Page Title -->


    <!-- Service Details Section -->
    <section id="service-details" class="service-details section light-background">

      <div class="container">

        <div class="row gy-4">

          <div class="col-lg-8">

            <div class="content">
              
              <h3>Deliverables</h3>

              <div class="features mt-4">
                <div class="row gy-4">
                  <div class="col-md-6">
                     <div class="feature-box d-flex align-items-center">
                      <i class="bi bi-check"></i>
                      <h4>SolidWorks CAD models (parts/assemblies)</h4>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="feature-box d-flex align-items-center">
                      <i class="bi bi-check"></i>
                      <h4>STEP / IGES files</h4>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="feature-box d-flex align-items-center">
                      <i class="bi bi-check"></i>
                      <h4>Clean, editable parametric models</h4>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="feature-box d-flex align-items-center">
                      <i class="bi bi-check"></i>
                      <h4>Optional technical drawings</h4>
                    </div>
                  </div>
                </div>
              </div>

              
              <h3 class="mt-5">Scope of Work</h3>
              <p>
                <ul>
                  <li>3D modeling from images, sketches, or PDFs</li>
                  <li>Reconstruction from existing parts or references</li>
                  <li>Geometry cleanup and optimization</li>
                  <li>Parametric rebuilding for future modification</li>
                </ul>
              </p>


            </div>
          </div>

          <div class="col-lg-4">

            <div class="related-services mt-5">
              <h4>Related Services</h4>
              <div class="service-item">
                <i class="bi bi-gear-wide-connected"></i>
                <h5><a href="system">Mechanical System Design</a></h5>
              </div>
              <div class="service-item">
                <i class="bi bi-box"></i>
                <h5><a href="cad">SolidWorks CAD Modeling</a></h5>
              </div>
              <div class="service-item">
                <i class="bi bi-file-earmark-text"></i>
                <h5><a href="drawings">Engineering Drawings & Fabrication Documentation</a></h5>
              </div>
            </div>
          </div>

        </div>

      </div>

    </section><!-- /Service Details Section -->

  </main>

</BaseLayout>