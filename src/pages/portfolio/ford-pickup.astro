---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="1979 Ford Pickup">

    <main class="main">

    <!-- Page Title -->
    <div class="page-title">
      <div class="breadcrumbs">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/"><i class="bi bi-house"></i> Home</a></li>
            <li class="breadcrumb-item"><a href="/portfolio">Portfolio</a></li>
            <li class="breadcrumb-item active current">1979 Ford Pickup</li>
          </ol>
        </nav>
      </div>

      <div class="container section-title pb-0">
        <h2>1979 Ford Pickup</h2>
        <div class="title-shape">
          <svg viewBox="0 0 200 20" xmlns="http://www.w3.org/2000/svg">
            <path d="M 0,10 C 40,0 60,20 100,10 C 140,0 160,20 200,10" fill="none" stroke="currentColor" stroke-width="2"></path>
          </svg>
        </div>
      </div><!-- End Section Title -->
    </div><!-- End Page Title -->

    <!-- Portfolio Details Section -->
    <section id="portfolio-details" class="portfolio-details section">

      <div class="container">

        <div class="row gy-4 g-lg-5">
          <div class="col-lg-6">
            <img src="/assets/img/portfolio/31.webp" class="img-fluid mb-4 rounded-4" alt="" loading="lazy">
            <img src="/assets/img/portfolio/32.webp" class="img-fluid mb-4 rounded-4" alt="" loading="lazy">
            <img src="/assets/img/portfolio/33.webp" class="img-fluid mb-4 rounded-4" alt="" loading="lazy">
            <img src="/assets/img/portfolio/34.webp" class="img-fluid mb-4 rounded-4" alt="" loading="lazy">
            <img src="/assets/img/portfolio/35.webp" class="img-fluid mb-4 rounded-4" alt="" loading="lazy">
          </div>

          <div class="col-lg-6">

            <div class="position-sticky" style="top: 40px">

            <div class="portfolio-description">
              <h2>Overview</h2>
              <p>
                Exterior-focused CAD reconstruction of a classic 1979 Ford Pickup based on reference images, developed for client-specific 3D printing requirements.
              </p>

              <div class="portfolio-info mt-5">
                <h2>Specifications</h2>
                <ul>
                  <li><strong>Model Type:</strong> Exterior surface model</li>
                  <li><strong>Source:</strong> Image-based reference reconstruction</li>
                  <li><strong>Geometry:</strong> Optimized for 3D printing</li>
                  <li><strong>Model Type:</strong> Static (non-parametric)</li>
                </ul>
              </div>

              <h2>Design Constraints</h2>
              <p>
                <ul>
                  <li>Reconstruct accurate vehicle proportions from limited image references</li>
                  <li>Ensure geometry is fully printable without surface defects</li>
                  <li>Maintain structural integrity for small-scale 3D printing</li>
                  <li>Optimize model for clean slicing and minimal print failure</li>
                </ul>
              </p>

              <div class="testimonial-item">
                <p>
                  <h2>⭐⭐⭐⭐⭐</h2>
                </p>
                <div>
                  <h3>J.T. Harrington</h3>
                  <h4>Client</h4>
                </div>
              </div>

              <h2>Design Approach</h2>
              <p>
                The model was reconstructed using image-based references, focusing on capturing key exterior proportions and recognizable design features of the vehicle.
                <br><br>
                Geometry was simplified and refined to ensure watertight surfaces and compatibility with FDM 3D printing processes.
              </p>

              <h2>Key Features</h2>
              <p>
                <ul>
                  <li>Accurate exterior reconstruction from reference images</li>
                  <li>Watertight geometry optimized for 3D printing</li>
                  <li>Clean surface transitions for improved print quality</li>
                  <li>Print-ready model validated through physical output</li>
                </ul>
              </p>

              <h2>Validation</h2>
              <p>
                <ul>
                  <li>Model successfully 3D printed by client</li>
                  <li>No major geometry or slicing issues reported</li>
                  <li>Final output confirmed structural and visual accuracy</li>
                </ul>
              </p>

              <h2>Outcome</h2>
              <p>
                Delivered a print-ready CAD model of a classic pickup truck, successfully validated through real-world 3D printing and client feedback.
              </p>

            </div>

              <div class="portfolio-info mt-5">
                <h3>Project information</h3>
                <ul>
                  <li><strong>Category</strong> Client Project</li>
                  <li><strong>Client</strong> J.T. Harrington</li>
                  <li><strong>Project date</strong> January, 2026</li>
                  <li><a href="https://www.upwork.com/freelancers/numanzamandipuu" class="btn-visit align-self-start" target="_blank">View Project on Upwork</a></li>
                </ul>
              </div>
            </div>

          </div>
        </div>

      </div>

    </section><!-- /Portfolio Details Section -->

    </main>

</BaseLayout>