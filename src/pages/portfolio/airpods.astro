---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Apple AirPods Pro">

    <main class="main">

    <!-- Page Title -->
    <div class="page-title">
      <div class="breadcrumbs">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/"><i class="bi bi-house"></i> Home</a></li>
            <li class="breadcrumb-item"><a href="/portfolio">Portfolio</a></li>
            <li class="breadcrumb-item active current">Apple AirPods Pro</li>
          </ol>
        </nav>
      </div>

      <div class="container section-title pb-0">
        <h2>Apple AirPods Pro</h2>
        <div class="title-shape">
          <svg viewBox="0 0 200 20" xmlns="http://www.w3.org/2000/svg">
            <path d="M 0,10 C 40,0 60,20 100,10 C 140,0 160,20 200,10" fill="none" stroke="currentColor" stroke-width="2"></path>
          </svg>
        </div>
      </div><!-- End Section Title -->
    </div><!-- End Page Title -->

    <!-- Portfolio Details Section -->
    <section id="portfolio-details" class="portfolio-details section">

      <div class="container">

        <div class="row gy-4 g-lg-5">
          <div class="col-lg-6">
            <img src="/assets/img/portfolio/66.webp" class="img-fluid mb-4 rounded-4" alt="" loading="lazy">
            <img src="/assets/img/portfolio/67.webp" class="img-fluid mb-4 rounded-4" alt="" loading="lazy">
            <img src="/assets/img/portfolio/68.webp" class="img-fluid mb-4 rounded-4" alt="" loading="lazy">
            <img src="/assets/img/portfolio/69.webp" class="img-fluid mb-4 rounded-4" alt="" loading="lazy">
            <img src="/assets/img/portfolio/70.webp" class="img-fluid mb-4 rounded-4" alt="" loading="lazy">
          </div>

          <div class="col-lg-6">

            <div class="position-sticky" style="top: 40px">
              <div class="portfolio-description">
                <h2>Overview</h2>
                <p>
                  High-detail CAD model of Apple AirPods Pro developed from official product references, focusing on precision surface modeling and clean geometry reproduction.
                </p>

                <div class="portfolio-info mt-5">
                  <h2>Specifications</h2>
                  <ul>
                    <li><strong>Source:</strong> Official product reference images</li>
                    <li><strong>Focus:</strong> Advanced surface modeling</li>
                    <li><strong>Assembly:</strong> 4-part component assembly</li>
                    <li><strong>Rendering:</strong> Blender visualization</li>
                  </ul>
                </div>

                <h2>Design Constraints</h2>
                <p>
                  <ul>
                    <li>Accurately capture organic geometry from image references</li>
                    <li>Maintain smooth surface continuity across complex curves</li>
                    <li>Ensure proportional accuracy of small-scale features</li>
                    <li>Handle high curvature transitions without surface artifacts</li>
                  </ul>
                </p>

                <h2>Design Approach</h2>
                <p>
                  The model was developed using reference images to replicate the organic form and smooth transitions characteristic of consumer electronics.
                  <br><br>
                  Advanced surfacing techniques were applied to achieve clean curvature and high-quality geometry across all visible surfaces.
                </p>

                <h2>Key Features</h2>
                <p>
                  <ul>
                    <li>Highly detailed organic surface modeling</li>
                    <li>Clean curvature transitions with no visible discontinuities</li>
                    <li>Multi-part assembly with consistent geometry alignment</li>
                    <li>High-quality rendered output for visualization</li>
                  </ul>
                </p>

                <h2>Outcome</h2>
                <p>
                  Delivered a visually accurate and refined product model demonstrating strong capability in handling complex surface geometry and consumer product detailing.
                </p>

              </div>

              <div class="portfolio-info mt-5">
                <h3>Project information</h3>
                <ul>
                  <li><strong>Category</strong> Independent Project</li>
                  <li><strong>Project date</strong> June, 2025</li>
                  <li><strong>Project URL</strong> <a href="https://grabcad.com/library/airpods-pro-3">https://grabcad.com/library/airpods-pro-3</a></li>
                  <li><a href="https://grabcad.com/library/airpods-pro-3" class="btn-visit align-self-start">Download CAD Files</a></li>
                </ul>
              </div>
            </div>

          </div>
        </div>

      </div>

    </section><!-- /Portfolio Details Section -->

    </main>

</BaseLayout>