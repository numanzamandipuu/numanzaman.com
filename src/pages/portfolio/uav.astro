---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Fixed-Wing UAV Structural Airframe">

    <main class="main">

    <!-- Page Title -->
    <div class="page-title">
      <div class="breadcrumbs">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/"><i class="bi bi-house"></i> Home</a></li>
            <li class="breadcrumb-item"><a href="/portfolio">Portfolio</a></li>
            <li class="breadcrumb-item active current">Fixed-Wing UAV Structural Airframe</li>
          </ol>
        </nav>
      </div>

      <div class="container section-title pb-0">
        <h2>Fixed-Wing UAV Structural Airframe</h2>
        <div class="title-shape">
          <svg viewBox="0 0 200 20" xmlns="http://www.w3.org/2000/svg">
            <path d="M 0,10 C 40,0 60,20 100,10 C 140,0 160,20 200,10" fill="none" stroke="currentColor" stroke-width="2"></path>
          </svg>
        </div>
      </div><!-- End Section Title -->
    </div><!-- End Page Title -->

    <!-- Portfolio Details Section -->
    <section id="portfolio-details" class="portfolio-details section">

      <div class="container">

        <div class="row gy-4 g-lg-5">
          <div class="col-lg-6">
            <img src="/assets/img/portfolio/41.webp" class="img-fluid mb-4 rounded-4" alt="" loading="lazy">
            <img src="/assets/img/portfolio/42.webp" class="img-fluid mb-4 rounded-4" alt="" loading="lazy">
            <img src="/assets/img/portfolio/43.webp" class="img-fluid mb-4 rounded-4" alt="" loading="lazy">
            <img src="/assets/img/portfolio/44.webp" class="img-fluid mb-4 rounded-4" alt="" loading="lazy">
            <img src="/assets/img/portfolio/45.webp" class="img-fluid mb-4 rounded-4" alt="" loading="lazy">
          </div>

          <div class="col-lg-6">

            <div class="position-sticky" style="top: 40px">
              <div class="portfolio-description">
                <h2>Overview</h2>
                <p>
                  Research-driven fixed-wing UAV developed for a competition. This design is focused on achieving structural strength and reliable payload-carrying capability within compact dimensional constraints.
                </p>
                <div class="portfolio-info mt-5">
                <h2>Specifications</h2>
                  <ul>
                    <li><strong>Length</strong> 42 in</li>
                    <li><strong>Wingspan</strong> 64 in</li>
                    <li><strong>Airfoil</strong> NACA 2412 (10 in chord)</li>
                    <li><strong>Fuselage Width</strong> 4.5 in</li>
                  </ul>
                </div>

                <h2>Design Focus</h2>
                <p>
                The airframe was designed to balance structural rigidity and payload capacity while maintaining aerodynamic efficiency. The NACA 2412 airfoil was selected for its stable lift characteristics and suitability for low-speed flight conditions.
                </p>
                
                <h2>Key Features</h2>
                <p>
                  <ul>
                    <li>Structural layout optimized for payload integration</li>
                    <li>Compact fuselage design for efficient packaging and transport</li>
                    <li>Wing geometry designed for stable and predictable flight behavior</li>
                  </ul>
                </p>

                <h2>Outcome</h2>
                <p>
                  The project demonstrates system-level understanding of UAV airframe design, integrating aerodynamic selection, structural layout, and mission-driven constraints into a unified configuration.
                </p>

              </div>

              <div class="portfolio-info mt-5">
                <h3>Project information</h3>
                <ul>
                  <li><strong>Category</strong> Independent Project</li>
                  <!-- <li><strong>Client</strong> ASU Company</li> -->
                  <li><strong>Project date</strong> November, 2025</li>
                  <li><strong>Project URL</strong> <a href="https://grabcad.com/library/fixed-wing-uav-structural-airframe-1">https://grabcad.com/library/fixed-wing-uav-structural-airframe-1</a></li>
                  <li><a href="https://grabcad.com/library/fixed-wing-uav-structural-airframe-1" class="btn-visit align-self-start">Download CAD Files</a></li>
                </ul>
              </div>
            </div>

          </div>
        </div>

      </div>

    </section><!-- /Portfolio Details Section -->

    </main>

</BaseLayout>