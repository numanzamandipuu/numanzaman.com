---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Dock Hardware Assembly">

    <main class="main">

    <!-- Page Title -->
    <div class="page-title">
      <div class="breadcrumbs">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/"><i class="bi bi-house"></i> Home</a></li>
            <li class="breadcrumb-item"><a href="/portfolio">Portfolio</a></li>
            <li class="breadcrumb-item active current">Dock Hardware Assembly</li>
          </ol>
        </nav>
      </div>

      <div class="container section-title pb-0">
        <h2>Dock Hardware Assembly</h2>
        <div class="title-shape">
          <svg viewBox="0 0 200 20" xmlns="http://www.w3.org/2000/svg">
            <path d="M 0,10 C 40,0 60,20 100,10 C 140,0 160,20 200,10" fill="none" stroke="currentColor" stroke-width="2"></path>
          </svg>
        </div>
      </div><!-- End Section Title -->
    </div><!-- End Page Title -->

    <!-- Portfolio Details Section -->
    <section id="portfolio-details" class="portfolio-details section">

      <div class="container">

        <div class="row gy-4 g-lg-5">
          <div class="col-lg-6">
            <img src="/assets/img/portfolio/16.webp" class="img-fluid mb-4 rounded-4" alt="" loading="lazy">
            <img src="/assets/img/portfolio/17.webp" class="img-fluid mb-4 rounded-4" alt="" loading="lazy">
            <img src="/assets/img/portfolio/18.webp" class="img-fluid mb-4 rounded-4" alt="" loading="lazy">
            <img src="/assets/img/portfolio/19.webp" class="img-fluid mb-4 rounded-4" alt="" loading="lazy">
            <img src="/assets/img/portfolio/20.webp" class="img-fluid mb-4 rounded-4" alt="" loading="lazy">
          </div>

          <div class="col-lg-6">

            <div class="position-sticky" style="top: 40px">
              <div class="portfolio-description">
                <h2>Overview</h2>
                <p>
                  Dimensionally accurate CAD assembly of dock hardware components developed from client-provided specifications, followed by structured exploded views for clear product visualization and web presentation.
                </p>

                <div class="portfolio-info mt-5">
                  <h2>Specifications</h2>
                  <ul>
                    <li><strong>Input:</strong> Client-provided dimensions</li>
                    <li><strong>Scope:</strong> Full component modeling and assembly</li>
                    <li><strong>Output:</strong> Exploded view visualizations</li>
                    <li><strong>Application:</strong> Website product display</li>
                  </ul>
                </div>

                <h2>Design Constraints</h2>
                <p>
                  <ul>
                    <li>Maintain strict dimensional accuracy based on provided data</li>
                    <li>Ensure proper fit between all mating components</li>
                    <li>Model each part separately before assembly integration</li>
                    <li>Create clear and readable exploded views for presentation</li>
                  </ul>
                </p>
                
                <div class="testimonial-item">
                  <p>
                    <h2>⭐⭐⭐⭐⭐</h2>
                  </p>
                  <div>
                    <h3>Joseph Rogers</h3>
                    <h4>Client</h4>
                  </div>
                </div>

                <h2>Design Approach</h2>
                <p>
                  Individual components were modeled based on provided dimensions and assembled to ensure accurate fit and alignment.
                  <br><br>
                  Exploded views were then generated to clearly communicate part relationships, assembly sequence, and component structure for client-facing visualization.
                </p>

                <h2>Key Features</h2>
                <p>
                  <ul>
                    <li>Complete multi-component assembly with accurate fit</li>
                    <li>Structured exploded views for clear visualization</li>
                    <li>Clean separation of components for readability</li>
                    <li>Optimized presentation for web-based product display</li>
                  </ul>
                </p>

                <h2>Deliverables</h2>
                <p>
                  <ul>
                    <li>Complete CAD assembly of all hardware components</li>
                    <li>High-resolution exploded view images</li>
                    <li>Multiple viewing angles for presentation use</li>
                    <li>Ready-to-use visuals for website integration</li>
                  </ul>
                </p>

                <h2>Outcome</h2>
                <p>
                  Delivered clear and structured assembly visuals that effectively communicate product structure and component relationships for client website integration.
                </p>

              </div>

              <div class="portfolio-info mt-5">
                <h3>Project information</h3>
                <ul>
                  <li><strong>Category</strong> Client Project</li>
                  <li><strong>Client</strong> Joseph Rogers</li>
                  <li><strong>Project date</strong> October, 2025</li>
                  <li><a href="https://www.upwork.com/freelancers/numanzamandipuu" class="btn-visit align-self-start" target="_blank">View Project on Upwork</a></li>
                </ul>
              </div>
            </div>

          </div>
        </div>

      </div>

    </section><!-- /Portfolio Details Section -->

    </main>

</BaseLayout>