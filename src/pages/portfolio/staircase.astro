---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Industrial Steel Staircase">

    <main class="main">

    <!-- Page Title -->
    <div class="page-title">
      <div class="breadcrumbs">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/"><i class="bi bi-house"></i> Home</a></li>
            <li class="breadcrumb-item"><a href="/portfolio">Portfolio</a></li>
            <li class="breadcrumb-item active current">Industrial Steel Staircase</li>
          </ol>
        </nav>
      </div>

      <div class="container section-title pb-0">
        <h2>Industrial Steel Staircase</h2>
        <div class="title-shape">
          <svg viewBox="0 0 200 20" xmlns="http://www.w3.org/2000/svg">
            <path d="M 0,10 C 40,0 60,20 100,10 C 140,0 160,20 200,10" fill="none" stroke="currentColor" stroke-width="2"></path>
          </svg>
        </div>
      </div><!-- End Section Title -->
    </div><!-- End Page Title -->

    <!-- Portfolio Details Section -->
    <section id="portfolio-details" class="portfolio-details section">

      <div class="container">

        <div class="row gy-4 g-lg-5">
          <div class="col-lg-6">
            <img src="/assets/img/portfolio/61.webp" class="img-fluid mb-4 rounded-4" alt="" loading="lazy">
            <img src="/assets/img/portfolio/62.webp" class="img-fluid mb-4 rounded-4" alt="" loading="lazy">
            <img src="/assets/img/portfolio/63.webp" class="img-fluid mb-4 rounded-4" alt="" loading="lazy">
            <img src="/assets/img/portfolio/64.webp" class="img-fluid mb-4 rounded-4" alt="" loading="lazy">
            <img src="/assets/img/portfolio/65.webp" class="img-fluid mb-4 rounded-4" alt="" loading="lazy">
          </div>

          <div class="col-lg-6">

            <div class="position-sticky" style="top: 40px">
              <div class="portfolio-description">
                <h2>Overview</h2>
                <p>
                  Industrial steel staircase designed for factory use, developed as a fabrication-ready structural assembly following standard design guidelines and practical installation requirements.
                </p>

                <div class="portfolio-info mt-5">
                  <h2>Specifications</h2>
                  <ul>
                    <li><strong>Application:</strong> Industrial / factory access</li>
                    <li><strong>Material:</strong> Structural steel with reinforcement</li>
                    <li><strong>Construction:</strong> Welded and bolted assembly</li>
                    <li><strong>Design Basis:</strong> Standard industrial staircase guidelines</li>
                  </ul>
                </div>

                <h2>Design Constraints</h2>
                <p>
                  <ul>
                    <li>Ensure stable and safe access within industrial environment</li>
                    <li>Maintain proper step geometry and ergonomic proportions</li>
                    <li>Design for practical fabrication and on-site assembly</li>
                    <li>Follow standard staircase design references and guidelines</li>
                  </ul>
                </p>

                <h2>Design Approach</h2>
                <p>
                  The staircase was designed using weldment and sheet metal features to create a structurally consistent and fabrication-ready assembly.
                  <br><br>
                  Standard proportions for tread, rise, and railing geometry were applied to ensure usability and compliance with typical industrial practices.
                </p>

                <h2>Key Features</h2>
                <p>
                  <ul>
                    <li>Fabrication-ready structural assembly using standard profiles</li>
                    <li>Combination of welded and bolted joints for flexibility</li>
                    <li>Integrated railing and support system for safety</li>
                    <li>Design aligned with common industrial staircase standards</li>
                  </ul>
                </p>

                <h2>Outcome</h2>
                <p>
                  Delivered a practical and fabrication-ready industrial staircase design suitable for factory environments, balancing structural clarity, manufacturability, and standard compliance.
                </p>

              </div>

              <div class="portfolio-info mt-5">
                <h3>Project information</h3>
                <ul>
                  <li><strong>Category</strong> Independent Project</li>
                  <li><strong>Project date</strong> June, 2025</li>
                  <li><strong>Project URL</strong> <a href="https://grabcad.com/library/industrial-staircase-3">https://grabcad.com/library/industrial-staircase-3</a></li>
                  <li><strong>Workflow Recording</strong> <a href="https://www.youtube.com/watch?v=ZftKgnCHYbo">YouTube Video</a></li>
                  <li><a href="https://grabcad.com/library/industrial-staircase-3" class="btn-visit align-self-start">Download CAD Files</a></li>
                </ul>
              </div>
            </div>

          </div>
        </div>

      </div>

    </section><!-- /Portfolio Details Section -->

    </main>

</BaseLayout>