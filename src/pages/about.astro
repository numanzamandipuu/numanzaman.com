---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About">

    <main class="main">
    <!-- Page Title -->
    <div class="page-title">
    <div class="breadcrumbs">
        <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/"><i class="bi bi-house"></i> Home</a></li>
            <!-- <li class="breadcrumb-item"><a href="#">Category</a></li> -->
            <li class="breadcrumb-item active current">About</li>
        </ol>
        </nav>
    </div>

    <!-- Section Title -->
    <div class="container section-title">
        <h2>About</h2>
        <div class="title-shape">
        <svg viewBox="0 0 200 20" xmlns="http://www.w3.org/2000/svg">
            <path d="M 0,10 C 40,0 60,20 100,10 C 140,0 160,20 200,10" fill="none" stroke="currentColor" stroke-width="2"></path>
        </svg>
        </div>
        <p>Mechanical Engineer specializing in production-ready mechanical system design and SolidWorks. Focused on manufacturable designs, structural reasoning, and system-level assemblies.</p>
    </div><!-- End Section Title -->
    </div><!-- End Page Title -->


    <!-- About Section -->
    <section id="about" class="about section light-background">

      <div class="container">

        <div class="row align-items-center">

          <div class="col-lg-6">
            <div class="about-content">
              <span class="subtitle">Professional Profile</span>

              <h2>Mechanical Engineer & SolidWorks CAD Specialist</h2>

              <p class="lead mb-4">I design production-ready mechanical systems where structural reasoning, assembly logic, and manufacturing constraints are integrated directly into the CAD model.</p>

              <p class="mb-4">My work focuses on system-level mechanical assemblies such as structural systems, industrial hardware, and detailed mechanical reconstructions.</p>

              <div class="personal-info" style="background: rgb(255, 255, 255);">
                <div class="row g-4">
                  <div class="col-6">
                    <div class="info-item">
                      <span class="label">Experience</span>
                      <span class="value">Freelance Mechanical Design Engineer</span>
                    </div>
                  </div>

                  <div class="col-6">
                    <div class="info-item">
                      <span class="label">Education</span>
                      <span class="value">Mechanical Engineering — RUET</span>
                    </div>
                  </div>

                  <div class="col-6">
                    <div class="info-item">
                      <span class="label">Certification</span>
                      <span class="value">CSWP | 4x CSWPA</span>
                    </div>
                  </div>

                  <div class="col-6">
                    <div class="info-item">
                      <span class="label">Specialization</span>
                      <span class="value">SolidWorks CAD & Mechanical System Design</span>
                    </div>
                  </div>

                  <div class="col-6">
                    <div class="info-item">
                      <span class="label">Capabilities</span>
                      <span class="value">Parametric CAD <br> Structural Assemblies <br> Manufacturing Drawings</span>
                    </div>
                  </div>

                  <div class="col-6">
                    <div class="info-item">
                      <span class="label">Primary Tools</span>
                      <span class="value">SolidWorks, Blender, ANSYS Fluent</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          
          <div class="col-lg-6 position-relative">
            <div class="about-image">
              <img src="assets/img/hero-img.jpg" alt="Profile Image" class="img-fluid rounded-4">
            </div>
          </div>

        </div>

      </div>

    </section><!-- /About Section -->

    
    <!-- Resume Section -->
    <section id="resume" class="resume section">

      <!-- Section Title -->
      <div class="container section-title">
        <h2>Resume</h2>
        <div class="title-shape">
          <svg viewBox="0 0 200 20" xmlns="http://www.w3.org/2000/svg">
            <path d="M 0,10 C 40,0 60,20 100,10 C 140,0 160,20 200,10" fill="none" stroke="currentColor" stroke-width="2"></path>
          </svg>
        </div>
      </div><!-- End Section Title -->

      <div class="container">

        <div class="row">
          <div class="col-12">
            <div class="resume-wrapper">
              <div class="resume-block">
                <h2>Experience</h2>
                <!-- <p class="lead">Maecenas tempus tellus eget condimentum rhoncus sem quam semper libero sit amet adipiscing sem neque sed ipsum.</p> -->

                <div class="timeline">
                  <div class="timeline-item">
                    <div class="timeline-left">
                      <!-- <h4 class="company">Elsevier</h4> -->
                      <span class="period">October, 2025 - Present</span>
                    </div>
                    <div class="timeline-dot"></div>
                    <div class="timeline-right">
                      <h3 class="position">Upwork</h3>
                      <p class="description">Mechanical Design Engineer</p>
                      <p>
                        <ul>
                          <li>Design and analysis of mechanical components.</li>
                          <li>Creation of 3D models and engineering drawings.</li>
                          <li>Collaboration with clients to understand requirements.</li>
                        </ul>
                      </p>
                    </div>
                  </div>

                </div>
              </div>

              <div class="resume-block">
                <h2>Education</h2>
                <!-- <p class="lead">Maecenas tempus tellus eget condimentum rhoncus sem quam semper libero sit amet adipiscing.</p> -->

                <div class="timeline">
                  <div class="timeline-item">
                    <div class="timeline-left">
                      <!-- <h4 class="company">ICMERE 2025</h4> -->
                      <span class="period">Jauary, 2023 - Present</span>
                    </div>
                    <div class="timeline-dot"></div>
                    <div class="timeline-right">
                      <h3 class="position">Rajshahi University of Engineering & Technology</h3>
                      <p class="description">B.Sc. in Mechanical Engineering</p>

                    </div>
                  </div>

                  <div class="timeline-item">
                    <div class="timeline-left">
                      <!-- <h4 class="company">ICERIE 2025</h4> -->
                      <span class="period">2019 - 2022</span>
                    </div>
                    <div class="timeline-dot"></div>
                    <div class="timeline-right">
                      <h3 class="position">Dhaka College</h3>
                      <p class="description">Higher Secondary Certificate</p>
                    </div>
                  </div>
                  
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>

    </section><!-- /Resume Section -->

    <!-- Skills Section -->
    <section id="skills" class="skills section light-background">

    <!-- Section Title -->
      <div class="container section-title">
        <h2>Skills</h2>
        <div class="title-shape">
          <svg viewBox="0 0 200 20" xmlns="http://www.w3.org/2000/svg">
            <path d="M 0,10 C 40,0 60,20 100,10 C 140,0 160,20 200,10" fill="none" stroke="currentColor" stroke-width="2"></path>
          </svg>
        </div>
      </div><!-- End Section Title -->


      <div class="container">

        <div class="row g-4 skills-animation">

          <div class="col-md-6 col-lg-3">
            <div class="skill-box">
              <h3>SolidWorks</h3>
              <p>Parametric CAD, complex assemblies, and production-ready manufacturing drawings.</p>
              <span class="text-end d-block">95%</span>
              <div class="progress">
                <div class="progress-bar" role="progressbar" aria-valuenow="95" aria-valuemin="0" aria-valuemax="100"></div>
              </div>
            </div>
          </div>

          <div class="col-md-6 col-lg-3">
            <div class="skill-box">
              <h3>ANSYS Fluent</h3>
              <p>CFD analysis for aerodynamic performance, airfoil studies, and flow behavior evaluation.</p>
              <span class="text-end d-block">75%</span>
              <div class="progress">
                <div class="progress-bar" role="progressbar" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100"></div>
              </div>
            </div>
          </div>

          <div class="col-md-6 col-lg-3">
            <div class="skill-box">
              <h3>AutoCAD</h3>
              <p>2D engineering drawings and drafting aligned with fabrication and documentation standards.</p>
              <span class="text-end d-block">80%</span>
              <div class="progress">
                <div class="progress-bar" role="progressbar" aria-valuenow="80" aria-valuemin="0" aria-valuemax="100"></div>
              </div>
            </div>
          </div>

          <div class="col-md-6 col-lg-3">
            <div class="skill-box">
              <h3>Blender</h3>
              <p>Technical visualization and presentation of mechanical systems.</p>
              <span class="text-end d-block">60%</span>
              <div class="progress">
                <div class="progress-bar" role="progressbar" aria-valuenow="60" aria-valuemin="0" aria-valuemax="100">
                </div>
              </div>
            </div>
          </div>

        </div>

      </div>

    </section><!-- /Skills Section -->

    <!-- Skills Section -->
    <section id="skills" class="skills section">

    <!-- Section Title -->
      <div class="container section-title">
        <h2>Licenses & Certifications</h2>
        <div class="title-shape">
          <svg viewBox="0 0 200 20" xmlns="http://www.w3.org/2000/svg">
            <path d="M 0,10 C 40,0 60,20 100,10 C 140,0 160,20 200,10" fill="none" stroke="currentColor" stroke-width="2"></path>
          </svg>
        </div>
      </div><!-- End Section Title -->


        <div class="container">

        <div class="row g-4 justify-content-center">

            <!-- CSWA -->
            <div class="col-6 col-lg-4">
            <div class="cert-box text-center">
                <img src="/assets/img/certificates/cswa.png" alt="CSWA">
                <h3><a href="https://www.credly.com/badges/226a7b77-5c3b-4d40-918c-0e1f5f2cfc57/public_url" target="_blank" rel="noopener noreferrer">SOLIDWORKS Design Associate (CSWA)</a></h3>
            </div>
            </div>

            <!-- CSWP -->
            <div class="col-6 col-lg-4">
            <div class="cert-box text-center">
                <img src="/assets/img/certificates/cswp.png" alt="CSWP">
                <h3><a href="https://www.credly.com/badges/97fc821d-858a-4edf-896f-5a3306bf3888/public_url" target="_blank" rel="noopener noreferrer">SOLIDWORKS Design Professional (CSWP)</a></h3>
            </div>
            </div>

            <!-- CSWP Sheet Metal -->
            <div class="col-6 col-lg-4">
            <div class="cert-box text-center">
                <img src="/assets/img/certificates/cswp-sheetmetal.png" alt="CSWP Sheet Metal">
                <h3><a href="https://www.credly.com/badges/71036aa4-0ddd-4e9f-98a6-a0517f8387f5/public_url" target="_blank" rel="noopener noreferrer">SOLIDWORKS Sheet Metal Professional</a></h3>
            </div>
            </div>

            <!-- CSWP Weldments -->
            <div class="col-6 col-lg-4">
            <div class="cert-box text-center">
                <img src="/assets/img/certificates/cswp-weldments.png" alt="CSWP Weldments">
                <h3><a href="https://www.credly.com/badges/cd7b86bc-9bae-431d-8d6e-03b812900ef4/public_url" target="_blank" rel="noopener noreferrer">SOLIDWORKS Weldments Professional</a></h3>
            </div>
            </div>

            <!-- CSWP Drawing -->
            <div class="col-6 col-lg-4">
            <div class="cert-box text-center">
                <img src="/assets/img/certificates/cswp-drawing.png" alt="CSWP Drawing">
                <h3><a href="https://www.credly.com/badges/850017c1-6fcd-4ced-aecb-55dd695f326d/public_url" target="_blank" rel="noopener noreferrer">SOLIDWORKS Drawing Tools Professional</a></h3>
            </div>
            </div>

            <!-- CSWP Surfacing -->
            <div class="col-6 col-lg-4">
            <div class="cert-box text-center">
                <img src="/assets/img/certificates/cswp-surfacing.png" alt="CSWP Surfacing">
                <h3><a href="https://www.credly.com/badges/e4a2f860-fcc9-44bc-8b0e-03ff2a65150f/public_url" target="_blank" rel="noopener noreferrer">SOLIDWORKS Surfacing Professional</a></h3>
            </div>
            </div>

        </div>

        </div>

    </section><!-- /Skills Section -->

    </main>

</BaseLayout>