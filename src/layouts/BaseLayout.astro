---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
const { title = "Numan Zaman Dipu" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta content="width=device-width, initial-scale=1.0" name="viewport">
  <title>{title}</title>
  <meta name="description" content="Mechanical engineer, researcher, and CAD specialist focused on production-ready system design, computational analysis, and manufacturable engineering solutions.">
  <meta name="keywords" content="">

  <!-- Favicons -->
  <link rel="icon" type="image" href="/assets/img/favicon.png">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">


  <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": "https://numanzaman.com/#person",
  "name": "Numan Zaman Dipu",
  "url": "https://numanzaman.com",
  "image": "https://numanzaman.com/assets/img/hero-img.jpg",

  "sameAs": [
    "https://www.linkedin.com/in/numanzamandipuu/",
    "https://www.researchgate.net/profile/Numan-Zaman-Dipu",
    "https://scholar.google.com/citations?user=snKFewUAAAAJ&hl=en",
    "https://github.com/numanzamandipuu",
    "https://www.upwork.com/freelancers/numanzamandipuu",
    "https://www.facebook.com/numanzamandipu",
    "https://www.youtube.com/@numanzamandipuu",
    "https://www.instagram.com/numanzamandipuu"
  ],

  "jobTitle": "Mechanical Engineer, Researcher, and Computational Design Specialist",

  "worksFor": {
    "@type": "Organization",
    "name": "Independent Mechanical Engineering Practice"
  },

  "alumniOf": {
    "@type": "CollegeOrUniversity",
    "name": "Rajshahi University of Engineering & Technology"
  },

  "email": "mailto:numanzamandipuu@gmail.com",

  "knowsLanguage": ["English", "Bengali"],

  "description": "Mechanical engineer and researcher specializing in production-ready mechanical system design, CAD-based engineering workflows, and computational analysis. Focused on manufacturable structural systems, UAV airframes, and CFD-driven aerodynamic optimization using SolidWorks, MATLAB, and simulation tools.",

  "knowsAbout": [
    "Mechanical Engineering",
    "SolidWorks CAD",
    "Parametric Modeling",
    "Mechanical System Design",
    "Engineering Simulation",
    "Computational Fluid Dynamics",
    "MATLAB Programming",
    "Engineering Research",
    "Design for Manufacturing",
    "Structural Design"
  ],

  "hasOccupation": {
    "@type": "Occupation",
    "name": "Mechanical Engineer",
    "skills": [
      "CAD Modeling",
      "Simulation",
      "Engineering Analysis",
      "Design Optimization"
    ]
  },

  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "https://numanzaman.com",
    "name": "Numan Zaman Dipu - Mechanical Engineer Portfolio"
  }
}
</script>

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com" rel="preconnect">
  <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900&family=Noto+Sans:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Questrial:wght@400&display=swap" rel="stylesheet">

  <!-- Vendor CSS Files -->
  <link href="/assets/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link href="/assets/vendor/bootstrap-icons/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/assets/vendor/glightbox/css/glightbox.min.css" rel="stylesheet">
  <link href="/assets/vendor/swiper/swiper-bundle.min.css" rel="stylesheet">

  <!-- Main CSS File -->
  <link href="/assets/css/main.css" rel="stylesheet">
</head>

<body>

  <Navbar />

  <main>
    <slot />
  </main>

  <Footer />

  <!-- Scroll Top -->
  <a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center">
    <i class="bi bi-arrow-up-short"></i>
  </a>

  <!-- Vendor JS Files -->
  <script is:inline src="/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script is:inline src="/assets/vendor/waypoints/noframework.waypoints.js"></script>
  <script is:inline src="/assets/vendor/glightbox/js/glightbox.min.js"></script>
  <script is:inline src="/assets/vendor/imagesloaded/imagesloaded.pkgd.min.js"></script>
